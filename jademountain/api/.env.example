# Trailforge API — copy to .env (NEVER commit .env)

# Anthropic API key for the Haiku call.
# Get one from https://console.anthropic.com/.
ANTHROPIC_API_KEY=sk-ant-...

# Override model if needed. Default is Haiku 4.5 (cheapest, fastest, fits the skill bundle).
# TRAILFORGE_MODEL=claude-haiku-4-5-20251001

# Port for the local Bun server (default 4100). Container default is also 4100.
# PORT=4100

# CORS allow-list. Comma-separated, no trailing slash.
ALLOWED_ORIGINS=https://aiwalkcorp.com,http://localhost:8000

# Override the path to the skill bundle. Defaults to ../skill (dev) or /app/skill (container).
# SKILL_DIR=../skill
